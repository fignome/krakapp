{
  "rewrites": [
    { "source": "/nhl-api/(.*)", "destination": "https://api-web.nhle.com/$1" },
    { "source": "/nhl-stats/(.*)", "destination": "https://api.nhle.com/$1" },
    { "source": "/cache/roster.json",      "destination": "/api/cache/roster" },
    { "source": "/cache/standings.json",   "destination": "/api/cache/standings" },
    { "source": "/cache/playerstats.json", "destination": "/api/cache/playerstats" },
    { "source": "/((?!api/).*)",           "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron",         "schedule": "0 3 * * *" },
    { "path": "/api/update-cache", "schedule": "0 4 * * *" }
  ],
  "functions": {
    "api/rumors.js":                  { "maxDuration": 60 },
    "api/news.js":                    { "maxDuration": 60 },
    "api/lines.js":                   { "maxDuration": 60 },
    "api/cron.js":                    { "maxDuration": 60 },
    "api/update-cache.js":            { "maxDuration": 60 },
    "api/gamepreview-storylines.js":  { "maxDuration": 60 }
  }
}
